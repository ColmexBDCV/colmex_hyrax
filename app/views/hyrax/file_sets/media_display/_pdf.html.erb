<% if Hyrax.config.display_media_download_link? %>
    <div>
      <h2 class="sr-only"><%= t('hyrax.file_set.show.downloadable_content.heading') %></h2>
      <%#= image_tag thumbnail_url(file_set),
                    class: "representative-media",
                    alt: "",
                    role: "presentation" %>

      <iframe id="pdfIframe" src="<%= main_app.pdf_viewer_path(file_set) %>" data-pdf-src="<%= main_app.pdf_viewer_path(file_set) %>" style="width: 100%;height:950px"></iframe>
      <%= render "shared/download_link", file_set: file_set  %>

    </div>
    <script>

      $('a.table_of_contents').on('click', function(e) {
          e.preventDefault();
      });

      function go_to_page(num) {
        // ponytail: usa el visor nativo; si se requiere API fina de PDF, migrar a PDF.js npm mantenido.
        var pdfIframe = document.getElementById("pdfIframe");
        pdfIframe.src = pdfIframe.dataset.pdfSrc + "#page=" + num;
      }
    </script>
<% else %>
    <div>
        
      <%= image_tag thumbnail_url(file_set),
                    class: "representative-media",
                    alt: "",
                    role: "presentation" %>
    </div>
<% end %>
