<% if current_user.admin? %>
  <li class="h5">Usuarios</li>

  <li class="<%= 'active' if request.path == main_app.dashboard_users_path %>">
    <%= link_to main_app.dashboard_users_path do %>
      <span class="fa fa-users" aria-hidden="true"></span>
      <span class="sidebar-action-text">Administrar usuarios</span>
    <% end %>
  </li>

  <li class="<%= 'active' if request.path == main_app.new_dashboard_user_path %>">
    <%= link_to main_app.new_dashboard_user_path do %>
      <span class="fa fa-user-plus" aria-hidden="true"></span>
      <span class="sidebar-action-text">Registrar usuario</span>
    <% end %>
  </li>
<% end %>
